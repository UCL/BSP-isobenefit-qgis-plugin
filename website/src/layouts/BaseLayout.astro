---
import '../styles/tailwind.css'

const base = import.meta.env.BASE_URL
// pages pass title/description directly; markdown pages pass them via frontmatter
const { frontmatter } = Astro.props
const pageTitle = Astro.props.title ?? frontmatter?.title
const title = pageTitle ? `${pageTitle} · Isobenefit Urbanism QGIS Plugin` : 'Isobenefit Urbanism QGIS Plugin'
const description =
  Astro.props.description ??
  frontmatter?.description ??
  'Isobenefit Urbanism plugin for QGIS: walkable urban growth scenarios on real-world data'
---

<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Gareth Simons" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@200;300;400;500;600;700&display=swap"
    />
  </head>
  <body class="h-full w-full">
    <div class="app-container">
      <div class="app-content">
        <nav class="site-nav">
          <a href={base}>Introduction</a>
          <a href={`${base}plugin/`}>Plugin guide</a>
          <a href={`${base}scenarios/`}>Scenarios</a>
          <a href={`${base}theory/`}>Theory</a>
        </nav>
        <slot />
      </div>
    </div>
  </body>
</html>

<style>
  .app-container {
    @apply flex h-full min-h-screen w-full flex-col items-center;
  }
  .app-content {
    @apply flex w-full max-w-6xl flex-col items-stretch px-3 py-10;
  }
  .site-nav {
    @apply flex gap-6 border-b-1 border-theme pb-2 text-sm font-semibold;
  }
  .site-nav a {
    @apply no-underline;
  }
</style>
