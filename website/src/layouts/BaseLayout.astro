---
import '../styles/tailwind.css'

const base = import.meta.env.BASE_URL
// pages pass title/description directly; markdown pages pass them via frontmatter
const { frontmatter } = Astro.props
const pageTitle = Astro.props.title ?? frontmatter?.title
const title = pageTitle ? `${pageTitle} · Isobenefit Urbanism QGIS Plugin` : 'Isobenefit Urbanism QGIS Plugin'
const description =
  Astro.props.description ??
  frontmatter?.description ??
  'Isobenefit Urbanism plugin for QGIS: walkable urban growth scenarios on real-world data'
---

<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Gareth Simons" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@200;300;400;500;600;700&display=swap"
    />
  </head>
  <body class="h-full w-full">
    <div class="app-container" id="top">
      <div class="app-content">
        <header class="site-header">
          <a class="site-home" href={base} title="Home">
            <img src={`${base}favicon.svg`} alt="" width="30" height="30" />
            <span>Isobenefit Urbanism</span>
          </a>
          <nav class="site-nav">
            <a href={base}>Introduction</a>
            <a href={`${base}plugin/`}>Plugin guide</a>
            <a href={`${base}scenarios/`}>Scenarios</a>
            <a href={`${base}theory/`}>Theory</a>
          </nav>
        </header>
        <slot />
        <nav class="site-nav site-nav-footer">
          <a href={base}>Introduction</a>
          <a href={`${base}plugin/`}>Plugin guide</a>
          <a href={`${base}scenarios/`}>Scenarios</a>
          <a href={`${base}theory/`}>Theory</a>
          <a href="#top" class="to-top">Back to top ↑</a>
        </nav>
      </div>
    </div>
  </body>
</html>

<style>
  .app-container {
    @apply flex h-full min-h-screen w-full flex-col items-center;
  }
  .app-content {
    @apply flex w-full max-w-6xl flex-col items-stretch px-3 py-10;
  }
  .site-header {
    @apply flex flex-wrap items-center justify-between gap-x-6 gap-y-2 border-b-1 border-theme pb-2;
  }
  .site-home {
    @apply flex items-center gap-2 text-base font-semibold no-underline;
    font-family: 'Space Grotesk', sans-serif;
  }
  .site-home img {
    @apply block;
  }
  .site-nav {
    @apply flex flex-wrap gap-6 text-sm font-semibold;
  }
  .site-nav a {
    @apply no-underline;
  }
  .site-nav-footer {
    @apply mt-12 border-b-0 border-t-2 pb-0 pt-3;
    border-top-color: #d33130;
  }
  .site-nav-footer .to-top {
    @apply ml-auto;
  }
</style>
