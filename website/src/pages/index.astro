  <style>
    .toc {
      @apply my-3 flex flex-wrap gap-x-4 gap-y-1 text-sm font-medium;
    }
    .toc a {
      @apply no-underline;
    }
    section {
      @apply border-t-1 border-theme pb-2;
    }
    /* Each simulation step is one visual unit: a light-GREY rule (a sub-divider that never competes
       with the red section rules) leads the step, then its step-number heading, its figure and its
       text, kept tight together. The generous gap ABOVE the rule sets each step apart from the last. */
    .ca-step {
      @apply mt-8 pt-3;
      border-top: 1px solid #b4b4b4;
    }
    .ca-step h4 {
      @apply pt-0;
    }
    ol {
      @apply ml-4 list-decimal;
    }
    ol li {
      @apply my-2 text-sm font-light;
    }
    .diagram {
      @apply w-full max-w-4xl;
    }
    .demo {
      @apply w-full max-w-md;
    }
    .hero {
      @apply w-full max-w-2xl;
    }
    /* multi-panel figures (growth, clustering) expand to the full page width so the sub-panels stay legible */
    .wide {
      @apply w-full;
    }
    .demo-row {
      @apply flex flex-wrap items-start justify-center gap-4;
    }
    .demo-row figure {
      /* share the row: three dispersal figures sit side by side on desktop */
      @apply min-w-56 flex-1;
    }
    .demo-row .demo {
      @apply max-w-full;
    }
    .layer-grid {
      @apply grid grid-cols-2 gap-3 sm:grid-cols-4;
    }
    .layer-grid figure {
      /* top-align the images so caption length can't push panels out of line */
      @apply justify-start self-start;
    }
    .layer {
      @apply w-full;
    }
    footer {
      @apply mt-8 flex justify-center border-t-1 border-theme p-2 text-xs font-light italic;
    }
  </style>
</BaseLayout>
