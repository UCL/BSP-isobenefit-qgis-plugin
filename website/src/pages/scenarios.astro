---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Content as ScenarioNotes } from './_scenario_notes.md'

const base = import.meta.env.BASE_URL
---

<BaseLayout>
  <h1>Scenario library</h1>
  <h6>Real places, prepared data, precomputed parameter explorations</h6>

  <section>
    <p>
      Pick a scenario, then toggle between precomputed runs to see how the dials change the outcome.
      Every panel is a real simulation through the full pipeline (growth, then post-processing), run at a
      coarsened preview resolution with a fixed seed, so each one is exactly reproducible; formal runs
      happen in QGIS at the scenario's own resolution using the folders linked below. Built land is
      coloured by density tier (yellow to brown), mixed-use centres in reds, existing fabric muted,
      nature green, unbuildable blue.
    </p>
    <div id="explorer" data-base={base}>
      <div class="chooser" id="scenario-buttons"></div>
      <div class="chooser presets" id="preset-buttons"></div>
      <p class="preset-note" id="preset-note"></p>
      <figure>
        <img id="preset-image" alt="Precomputed scenario run" />
        <figcaption id="preset-caption"></figcaption>
      </figure>
      <div class="flex justify-center overflow-x-auto">
        <table id="metrics-table" style="display:none">
          <tr>
            <th>Served (walk to both)</th><th>Avg walk to centre</th><th>Avg walk to green</th>
            <th>New population</th><th>Centre m²/person</th><th>Green m²/person</th>
          </tr>
          <tr id="metrics-row"></tr>
        </table>
      </div>
      <div id="reproduce" style="display:none">
        <h3>Reproduce this run</h3>
        <ol>
          <li>Download the <a id="dl-zip" href="#">scenario data (ZIP)</a>: the extents, prepared OSM
              layers and parameter presets (also <a id="gh-link" href="#">browsable on GitHub</a>).</li>
          <li>Download <a id="dl-params" href="#">this run's parameters</a> (a plugin
              <code>params.json</code>).</li>
          <li>In QGIS, add the layers from the ZIP, open the run dialog, press
              <em>Load parameters</em> and pick the downloaded file, then choose the layers in the
              <em>Input layers</em> group (extents, built, green, unbuildable, centres, streets).</li>
          <li>Set an output path and press Run. The preview above used a coarsened grid; the loaded
              parameters run at the scenario's own resolution, so expect finer (and slower) results
              with the same character.</li>
        </ol>
        <details>
          <summary>Exact settings used by this run</summary>
          <div class="flex justify-center overflow-x-auto">
            <table id="settings-table"></table>
          </div>
        </details>
      </div>
    </div>
  </section>

  <ScenarioNotes />

  <style is:global>
    /* is:global because the buttons are created at runtime by the script below, so Astro's
       scoped-style attributes never reach them */
    .chooser {
      @apply my-2 flex flex-wrap justify-center gap-2;
    }
    .chooser button {
      @apply rounded border-1 border-light-grey bg-white px-3 py-1 text-sm;
      cursor: pointer;
    }
    .chooser button.active {
      @apply border-theme font-semibold text-theme;
    }
    .presets button {
      @apply text-xs;
    }
    .preset-note {
      @apply text-center italic;
    }
    #preset-image {
      @apply w-full max-w-3xl;
    }
  </style>

  <script>
    interface Preset {
      id: string
      label: string
      note: string
      image: string
      metrics: Record<string, number> | null
      settings: Record<string, unknown> | null
      params_file: string | null
    }
    interface Entry {
      id: string
      title: string
      subtitle: string
      grid: string
      seed: number
      github: string
      zip: string
      presets: Preset[]
    }

    const root = document.getElementById('explorer') as HTMLElement
    const base = root.dataset.base ?? '/'
    const scenarioBox = document.getElementById('scenario-buttons') as HTMLElement
    const presetBox = document.getElementById('preset-buttons') as HTMLElement
    const noteEl = document.getElementById('preset-note') as HTMLElement
    const img = document.getElementById('preset-image') as HTMLImageElement
    const caption = document.getElementById('preset-caption') as HTMLElement
    const table = document.getElementById('metrics-table') as HTMLElement
    const row = document.getElementById('metrics-row') as HTMLElement
    const repro = document.getElementById('reproduce') as HTMLElement
    const dlZip = document.getElementById('dl-zip') as HTMLAnchorElement
    const dlParams = document.getElementById('dl-params') as HTMLAnchorElement
    const ghLink = document.getElementById('gh-link') as HTMLAnchorElement
    const settingsTable = document.getElementById('settings-table') as HTMLElement

    const fmtM = (v: number) => `${Math.round(v)} m`
    const fmtPct = (v: number) => `${Math.round(v * 100)}%`
    const fmtN = (v: number) => Math.round(v).toLocaleString('en-GB')

    function fillSettings(settings: Record<string, unknown>) {
      settingsTable.innerHTML = ''
      const rows: [string, string][] = []
      for (const [key, value] of Object.entries(settings)) {
        if (value !== null && typeof value === 'object') {
          const parts = Object.entries(value as Record<string, unknown>).map(([k, v]) => `${k} ${v}`)
          rows.push([key, parts.join(' · ')])
        } else {
          rows.push([key, String(value)])
        }
      }
      for (const [key, value] of rows) {
        const tr = document.createElement('tr')
        const th = document.createElement('td')
        th.textContent = key
        const td = document.createElement('td')
        td.textContent = value
        tr.appendChild(th)
        tr.appendChild(td)
        settingsTable.appendChild(tr)
      }
    }

    function selectPreset(entry: Entry, preset: Preset) {
      img.src = `${base}gallery/${preset.image}`
      caption.textContent = `${entry.title}: ${preset.label}. ${entry.grid}, seed ${entry.seed}.`
      noteEl.textContent = preset.note
      const m = preset.metrics
      if (m === null) {
        table.style.display = 'none'
        repro.style.display = 'none'
      } else {
        row.innerHTML = ''
        for (const v of [fmtPct(m.served_coverage), fmtM(m.centre_access), fmtM(m.green_access),
                         fmtN(m.population), String(Math.round(m.centre_m2_per_person)),
                         String(Math.round(m.green_m2_per_person))]) {
          const td = document.createElement('td')
          td.textContent = v
          row.appendChild(td)
        }
        table.style.display = ''
        dlZip.href = `${base}${entry.zip}`
        ghLink.href = entry.github
        if (preset.params_file) {
          dlParams.href = `${base}gallery/${preset.params_file}`
          dlParams.setAttribute('download', `${entry.id}_${preset.id}_params.json`)
        }
        if (preset.settings) fillSettings(preset.settings)
        repro.style.display = ''
      }
      for (const b of Array.from(presetBox.children) as HTMLElement[]) {
        b.classList.toggle('active', b.dataset.id === preset.id)
      }
    }

    function selectScenario(entries: Entry[], id: string) {
      const entry = entries.find((e) => e.id === id)
      if (!entry) return
      for (const b of Array.from(scenarioBox.children) as HTMLElement[]) {
        b.classList.toggle('active', b.dataset.id === id)
      }
      presetBox.innerHTML = ''
      for (const preset of entry.presets) {
        const b = document.createElement('button')
        b.textContent = preset.label
        b.dataset.id = preset.id
        b.addEventListener('click', () => selectPreset(entry, preset))
        presetBox.appendChild(b)
      }
      selectPreset(entry, entry.presets[0])
    }

    fetch(`${base}gallery/gallery.json`)
      .then((r) => r.json())
      .then((d: { entries: Entry[] }) => {
        for (const entry of d.entries) {
          const b = document.createElement('button')
          b.textContent = entry.title
          b.title = entry.subtitle
          b.dataset.id = entry.id
          b.addEventListener('click', () => selectScenario(d.entries, entry.id))
          scenarioBox.appendChild(b)
        }
        selectScenario(d.entries, d.entries[0].id)
      })
      .catch(() => {
        noteEl.textContent = 'The gallery could not be loaded.'
      })
  </script>
</BaseLayout>
