{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/ruff check *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(.venv/bin/python scripts/verify.py)",
      "Bash(.venv/bin/python scripts/prose_lint.py *)",
      "Bash(.venv/bin/python scripts/render_scenario_gallery.py)",
      "Bash(.venv/bin/python website/scripts/diagrams.py)",
      "Bash(.venv/bin/python website/scripts/demonstrators.py)",
      "Bash(cargo test *)",
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(npm run build)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; .venv/bin/python scripts/prose_lint.py \"$f\"; }",
            "timeout": 20,
            "statusMessage": "Checking prose patterns"
          }
        ]
      }
    ]
  }
}
